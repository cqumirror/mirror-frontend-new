# =============================================================================
# CQU Mirror 环境变量示例
# 使用：cp .env.example .env && 编辑必要项
# =============================================================================

# ── Grafana 管理员密码（必填，初次部署后请立即修改）──────────────────────────
GRAFANA_PASSWORD=please-change-me

# ── 服务端口映射（可选，默认 80/443）────────────────────────────────────────
# HTTP_PORT=80
# HTTPS_PORT=443

# ── tunasync manager 地址（可选，默认 backend:12345，由 docker-compose 维护）──
# TUNASYNC_BACKEND=backend:12345

# ── 时区（可选，默认 Asia/Shanghai）────────────────────────────────────────
# TZ=Asia/Shanghai

# ── 站点正式域名（用于 SEO canonical / OG 标签，已在前端构建时硬编码）────────
# 修改后需重新构建前端
# SITE_ORIGIN=https://mirrors.cqu.edu.cn

# ── 数据 API 地址（Cloudflare Pages 等外部部署时必填）────────────────────────
# 本地开发留空（走 Vite proxy），Cloudflare 部署需设为 https://mirrors.cqu.edu.cn
# 构建时通过 VITE_ 前缀注入前端代码
# VITE_API_BASE=https://mirrors.cqu.edu.cn
