# =============================================================================
# CQU Mirror 前端环境变量
# =============================================================================

# ── 站点正式域名（用于 SEO canonical / OG 标签，已在前端构建时硬编码）────────
# 修改后需重新构建前端
# SITE_ORIGIN=https://mirrors.cqu.edu.cn

# ── 数据 API 地址（外部部署时必填）────────────────────────────────────────────
# 本地开发留空（走 Vite proxy），外部部署需设为 https://mirrors.cqu.edu.cn
# 构建时通过 VITE_ 前缀注入前端代码
# VITE_API_BASE=https://mirrors.cqu.edu.cn
